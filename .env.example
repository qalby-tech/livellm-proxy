
# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging & Monitoring
LOGFIRE_WRITE_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Persistence Configuration
# If REDIS_URL is provided, provider settings will be stored in Redis
# Otherwise, file storage is used at FILE_STORAGE_PATH
# Example: redis://localhost:6379/0 or redis://user:password@host:port/db
REDIS_URL=
FILE_STORAGE_PATH=/data/providers.json

# Encryption Salt (Optional, applies to both Redis and File storage)
# This salt is used to derive the encryption key for securing stored data
# If not provided, data will be stored unencrypted
# Generate a strong random string, e.g., using: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_SALT=

# Context Overflow Configuration
# Safety overhead multiplier for tiktoken token counting
# Default is 1.20 (20% buffer) to account for potential tiktoken inaccuracies
# Set higher (e.g., 1.30) for more safety, or 1.0 for no overhead
TOKEN_COUNT_OVERHEAD=1.20